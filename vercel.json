{
  "version": 2,
  "buildCommand": "pnpm run build:demo",
  "outputDirectory": "dist-demo",
  "functions": {
    "api/index.py": {
      "excludeFiles" :"{api/data/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}