{
  "version": 2,
  "buildCommand": "pnpm run build:demo",
  "outputDirectory": "dist-demo",
  "functions": {
    "server/index.py": {
      "runtime": "python3.11"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.py"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}