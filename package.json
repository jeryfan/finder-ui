{
  "name": "finder-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/finder-ui.umd.js",
  "module": "./dist/finder-ui.es.js",
  "types": "./dist/finder-ui.d.ts",
