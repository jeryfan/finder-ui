{
  "name": "@jeryfan/finder-ui",
  "version": "0.4.0",
  "type": "module",
  "license": "MIT",
  "description": "A macOS Finder-style file browser component for React",
  "keywords": [
    "react",
    "file-browser",
    "finder",
    "file-manager",
    "ui-component"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jeryfan/finder-ui.git"
  },
  "homepage": "https://github.com/jeryfan/finder-ui",
  "author": "jeryfan",
  "main": "./dist/finder-ui.umd.js",
  "module": "./dist/finder-ui.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": true,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/finder-ui.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/finder-ui.umd.js"
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@uiw/react-codemirror": "^4.20.0",
    "marked": "^17.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-codemirror": "^4.25.8",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "marked": "^17.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "zustand": "^5.0.11"
  },
  "dependencies": {
    "lucide-react": "^0.577.0"
  }
}
